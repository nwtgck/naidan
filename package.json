{
  "name": "naidan",
  "private": true,
  "version": "0.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && npm run build:all",
    "build:all": "npm run build:standalone && npm run build:hosted",
    "build:standalone": "vite build --mode standalone --logLevel warn",
    "build:hosted": "vite build --mode hosted --logLevel warn",
    "preview": "vite preview",
    "test": "vitest",
    "test:only-failed": "vitest --reporter=./src/FailedOnlyReporter.ts --run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@vueuse/core": "^14.3.0",
    "comlink": "^4.4.2",
    "dompurify": "^3.4.10",
    "file-type": "^22.0.1",
    "he": "^1.2.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-vue-next": "^0.562.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.10",
    "mathjs": "^15.2.0",
    "mermaid": "11.15.0",
    "nanoid": "^5.1.11",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^28.0.3",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/language-core": "^3.3.5",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vue/typescript": "^1.8.20",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.15",
    "rolldown": "1.0.3",
    "rollup-plugin-license": "^3.7.1",
    "systemjs": "6.15.1",
    "tailwindcss": "^4.3.1",
    "terser": "^5.44.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^3.4.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  }
